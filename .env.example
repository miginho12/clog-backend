# 환경
ENVIRONMENT=local
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=DEBUG
CORS_ORIGINS=["http://localhost:3000"]

# ─── Database ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clog_dev
DB_USER=clog
DB_PASSWORD=changeme

# ─── JWT ───
JWT_PRIVATE_KEY_PATH=./jwt-keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./jwt-keys/jwt-public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=RS256
JWT_ISSUER=clog-backend

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5
REDIS_CONNECT_TIMEOUT=5

# ─── Kakao OAuth (Day 12) ───
# 카카오 개발자 콘솔의 REST API 키
KAKAO_CLIENT_ID=your_kakao_rest_api_key_here

# Client Secret (콘솔에서 발급, 등록 안 했으면 빈 값)
KAKAO_CLIENT_SECRET=

# Redirect URI (카카오 콘솔에 등록한 URI 와 정확히 일치해야 함)
KAKAO_REDIRECT_URI=http://localhost:8000/auth/kakao/callback

# OAuth state TTL (CSRF 방어용)
OAUTH_STATE_TTL_SECONDS=300
