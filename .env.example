# 환경 (local | dev | prod)
ENVIRONMENT=local

# 서버
HOST=0.0.0.0
PORT=8000

# 로깅
LOG_LEVEL=DEBUG

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# ─── Database (PostgreSQL) ───
# 로컬 개발 시 k3s 의 PostgreSQL 에 port-forward 로 연결:
#   kubectl port-forward -n dev svc/postgres 5432:5432
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clog_dev
DB_USER=clog
DB_PASSWORD=changeme   # 실제 비밀번호로 변경 (kubectl get secret 으로 확인)

# Pool 설정 (선택)
# DB_POOL_SIZE=5
# DB_POOL_MAX_OVERFLOW=5
# DB_POOL_TIMEOUT=30
# DB_ECHO=false       # true 면 모든 SQL 출력 (디버깅용)
