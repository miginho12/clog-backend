# ────────────────────────────────────────
#  Clog Backend - 환경변수 예시
#  (Day 14 - 보안 강화 + Rate Limit + CORS)
# ────────────────────────────────────────

# ── 환경 ──
# local: 개발 PC (시뮬레이션 로그인 활성)
# dev:   K8s 개발 환경 (시뮬레이션 로그인 비활성)
# prod:  운영 (시뮬레이션 로그인 비활성)
ENVIRONMENT=local

# ── 기본 ──
APP_NAME=clog-backend
APP_VERSION=0.1.0
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=DEBUG

# ── CORS (Day 14 ⭐ 강화) ──
# JSON 배열 형태로 명시. 환경별로 다름.
# Pydantic v2 가 자동 파싱.
# 예: CORS_ORIGINS=["http://localhost:3000","https://clog.tail099985.ts.net"]
CORS_ORIGINS=["http://localhost:3000","https://clog.tail099985.ts.net"]

# ── 데이터베이스 (PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clog_dev
DB_USER=clog
DB_PASSWORD=your_db_password_here
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_ECHO=false

# ── JWT ──
# 옵션 A: 내용 직접 (escape \n)
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----\n"

# 옵션 B: 파일 경로 (권장)
JWT_PRIVATE_KEY_PATH=./jwt-keys/private.pem
JWT_PUBLIC_KEY_PATH=./jwt-keys/public.pem

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=clog-backend
JWT_ALGORITHM=RS256

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5
REDIS_CONNECT_TIMEOUT=5

# ── 카카오 OAuth (Day 12) ──
# 카카오 개발자 콘솔 (https://developers.kakao.com)
# 내 애플리케이션 > 앱 키 > REST API 키
KAKAO_CLIENT_ID=your_kakao_rest_api_key

# 카카오 로그인 > 보안 > Client Secret
# ⚠️ Day 13 에서 재발급한 새 값 사용
KAKAO_CLIENT_SECRET=your_kakao_client_secret

# 카카오 로그인 > Redirect URI
# 로컬: http://localhost:8000/auth/kakao/callback
# 운영: https://clog.tail099985.ts.net/auth/kakao/callback (K8s ConfigMap 에 있음)
KAKAO_REDIRECT_URI=http://localhost:8000/auth/kakao/callback

# state TTL (CSRF 방어, 5분)
OAUTH_STATE_TTL_SECONDS=300
