# 환경
ENVIRONMENT=local
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=DEBUG
CORS_ORIGINS=["http://localhost:3000"]

# ─── Database ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clog_dev
DB_USER=clog
DB_PASSWORD=changeme

# ─── JWT ───
JWT_PRIVATE_KEY_PATH=./jwt-keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./jwt-keys/jwt-public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=RS256
JWT_ISSUER=clog-backend

# ─── Redis (Day 11B) ───
# 로컬 개발 시 port-forward 로 K8s Redis 에 연결:
#   kubectl port-forward -n dev svc/redis 6379:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme   # K8s Secret 의 redis-password
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5
REDIS_CONNECT_TIMEOUT=5
